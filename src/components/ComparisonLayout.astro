---
import BaseLayout from '../layouts/BaseLayout.astro';

interface FeatureRow {
  feature: string;
  oneask: string | boolean;
  competitor: string | boolean;
}

interface Props {
  competitor: string;
  title: string;
  description: string;
  headline: string;
  subheadline: string;
  intro: string;
  features: FeatureRow[];
  testimonialQuote: string;
  testimonialAuthor: string;
  testimonialRole: string;
  testimonialPhoto: string;
  ctaText?: string;
}

const {
  competitor,
  title,
  description,
  headline,
  subheadline,
  intro,
  features,
  testimonialQuote,
  testimonialAuthor,
  testimonialRole,
  testimonialPhoto,
  ctaText = 'Get started now',
} = Astro.props;

function renderCell(val: string | boolean) {
  if (val === true) return { icon: '✅', text: '', isBool: true, isPos: true };
  if (val === false) return { icon: '—', text: '', isBool: true, isPos: false };
  return { icon: '', text: val as string, isBool: false, isPos: false };
}
---
<BaseLayout {title} {description}>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-indigo-700 to-purple-600 text-white py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl sm:text-5xl font-extrabold mb-4">{headline}</h1>
      <p class="text-xl text-indigo-100 mb-8">{subheadline}</p>
      <a href="https://admin.oneask.app/signup"
        class="inline-flex items-center px-8 py-3 rounded-full bg-white text-indigo-700 font-bold hover:bg-indigo-50 transition-colors shadow-lg">
        {ctaText}
      </a>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-14 bg-white">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <p class="text-lg text-gray-600 leading-relaxed">{intro}</p>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="py-10 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-center mb-8">Compare The Features</h2>
      <div class="overflow-x-auto rounded-2xl border border-gray-200 shadow-sm">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-indigo-600 text-white">
              <th class="px-6 py-4 text-left font-semibold">Feature</th>
              <th class="px-6 py-4 text-center font-semibold">OneAsk</th>
              <th class="px-6 py-4 text-center font-semibold">{competitor}</th>
            </tr>
          </thead>
          <tbody>
            {features.map((row, i) => {
              const oa = renderCell(row.oneask);
              const comp = renderCell(row.competitor);
              return (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                  <td class="px-6 py-4 text-gray-800 font-medium">{row.feature}</td>
                  <td class="px-6 py-4 text-center">
                    {oa.isBool ? (
                      <span class={oa.isPos ? 'text-green-600 font-bold text-lg' : 'text-gray-400'}>
                        {oa.icon}
                      </span>
                    ) : (
                      <span class="text-gray-700">{oa.text}</span>
                    )}
                  </td>
                  <td class="px-6 py-4 text-center">
                    {comp.isBool ? (
                      <span class={comp.isPos ? 'text-green-600 font-bold text-lg' : 'text-gray-400'}>
                        {comp.icon}
                      </span>
                    ) : (
                      <span class="text-gray-700">{comp.text}</span>
                    )}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <blockquote class="text-xl italic text-gray-700 mb-8 leading-relaxed">
        &ldquo;{testimonialQuote}&rdquo;
      </blockquote>
      <div class="flex items-center justify-center gap-4">
        <img src={testimonialPhoto} alt={testimonialAuthor} class="w-14 h-14 rounded-full object-cover" />
        <div class="text-left">
          <p class="font-semibold text-gray-900">{testimonialAuthor}</p>
          <p class="text-gray-500 text-sm">{testimonialRole}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="bg-indigo-600 text-white py-16">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to try OneAsk?</h2>
      <p class="text-indigo-100 mb-8">198 people signed up in the last week. Join them — it's free.</p>
      <a href="https://admin.oneask.app/signup"
        class="inline-flex items-center px-8 py-3 rounded-full bg-white text-indigo-700 font-bold hover:bg-indigo-50 transition-colors shadow-lg">
        {ctaText}
      </a>
    </div>
  </section>
</BaseLayout>
