---
import type { Lang } from '../i18n/index';
import { useTranslations } from '../i18n/index';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---
<section class="bg-indigo-700 text-white overflow-hidden">
  <div class="max-w-7xl mx-auto grid md:grid-cols-2 min-h-[520px]">

    <!-- Left column: text + form -->
    <div class="flex flex-col justify-center px-6 sm:px-10 lg:px-16 py-16 md:py-20">

      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-white/15 rounded-full px-4 py-1.5 text-sm font-medium mb-5 w-fit">
        <span class="w-2 h-2 rounded-full bg-green-400 shrink-0"></span>
        {t.hero.badge}
      </div>

      <!-- Heading -->
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold leading-tight mb-4">
        {t.hero.headline}
      </h1>

      <!-- Description -->
      <p class="text-base sm:text-lg text-indigo-100 mb-7 max-w-md">
        {t.hero.description}
      </p>

      <!-- Join Event Form -->
      <form
        onsubmit="join(event)"
        class="flex flex-col sm:flex-row gap-2 mb-5 max-w-md"
        locale={lang === 'pt-br' ? 'PORTUGUESE' : 'ENGLISH'}
        id="1925036636"
      >
        <input
          type="text"
          id="event-code"
          name="code"
          placeholder={t.hero.formPlaceholder}
          class="flex-1 px-5 py-3 rounded-full text-gray-900 text-sm font-medium placeholder-gray-400 outline-none focus:ring-2 focus:ring-white/40 min-w-0"
          autocomplete="off"
        />
        <button
          type="submit"
          class="px-7 py-3 rounded-full bg-white text-indigo-700 font-bold text-sm hover:bg-indigo-50 transition-colors shadow shrink-0"
        >
          {t.hero.formButton}
        </button>
      </form>

      <!-- CTA + social proof -->
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <a
          href="https://admin.oneask.app/signup"
          class="inline-flex items-center px-7 py-3 rounded-full bg-white/10 border border-white/25 text-white font-semibold text-sm hover:bg-white/20 transition-colors"
        >
          {t.hero.cta}
        </a>
        <span class="text-indigo-200 text-sm">
          <strong class="text-white">198</strong> {t.hero.signedUp}
        </span>
      </div>
    </div>

    <!-- Right column: event image -->
    <div class="relative hidden md:block">
      <img
        src="/images/hero-event.png"
        alt="Live event with engaged audience"
        class="absolute inset-0 w-full h-full object-cover object-center"
      />
      <!-- Gradient blend on the left edge -->
      <div class="absolute inset-0 bg-gradient-to-r from-indigo-700 via-indigo-700/30 to-transparent"></div>
    </div>

  </div>
</section>

<script>
  function join(e?: Event) {
    if (e) e.preventDefault();
    const code = (document.getElementById('event-code') as HTMLInputElement)?.value?.trim();
    if (code) {
      window.location.href = `https://admin.oneask.app/join/${code}`;
    }
  }
  (window as any).join = join;
</script>
