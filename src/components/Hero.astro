---
import type { Lang } from '../i18n/index';
import { useTranslations } from '../i18n/index';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---
<section class="relative overflow-hidden min-h-[540px] flex items-center">

  <!-- Background image -->
  <img
    src="/images/hero-event.png"
    alt="Live event with engaged audience"
    class="absolute inset-0 w-full h-full object-cover object-center"
  />

  <!-- Semi-transparent overlay -->
  <div class="absolute inset-0 bg-indigo-900/70"></div>

  <!-- Content -->
  <div class="relative w-full max-w-7xl mx-auto px-6 sm:px-10 lg:px-16 py-16 md:py-20">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-10">

      <!-- Left: headline + description -->
      <div class="text-white md:max-w-xl">
        <div class="inline-flex items-center gap-2 bg-white/15 rounded-full px-4 py-1.5 text-sm font-medium mb-5">
          <span class="w-2 h-2 rounded-full bg-green-400 shrink-0"></span>
          {t.hero.badge}
        </div>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold leading-tight mb-4">
          {t.hero.headline}
        </h1>
        <p class="text-base sm:text-lg text-indigo-100 mb-6 max-w-md">
          {t.hero.description}
        </p>
        <div class="flex items-center gap-2 text-sm text-indigo-200">
          <strong class="text-white">198</strong> {t.hero.signedUp}
        </div>
      </div>

      <!-- Right: join form + CTA -->
      <div class="w-full md:w-auto md:min-w-[340px] bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl p-6 text-white flex flex-col gap-4">
        <p class="font-semibold text-lg">{t.hero.badge}</p>

        <form
          onsubmit="join(event)"
          class="flex flex-col gap-3"
          locale={lang === 'pt-br' ? 'PORTUGUESE' : 'ENGLISH'}
          id="1925036636"
        >
          <input
            type="text"
            id="event-code"
            name="code"
            placeholder={t.hero.formPlaceholder}
            class="w-full px-5 py-3 rounded-xl bg-white text-gray-900 text-sm font-medium placeholder-gray-400 outline-none focus:ring-2 focus:ring-indigo-300"
            autocomplete="off"
          />
          <button
            type="submit"
            class="w-full px-7 py-3 rounded-xl bg-indigo-600 text-white font-bold text-sm hover:bg-indigo-500 transition-colors shadow"
          >
            {t.hero.formButton}
          </button>
        </form>

        <div class="border-t border-white/20 pt-4">
          <a
            href="https://admin.oneask.app/signup"
            class="block w-full text-center px-7 py-3 rounded-xl border border-white/30 text-white font-semibold text-sm hover:bg-white/10 transition-colors"
          >
            {t.hero.cta}
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  function join(e?: Event) {
    if (e) e.preventDefault();
    const code = (document.getElementById('event-code') as HTMLInputElement)?.value?.trim();
    if (code) {
      window.location.href = `https://admin.oneask.app/join/${code}`;
    }
  }
  (window as any).join = join;
</script>
